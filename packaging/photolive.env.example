# Required: bearer token clients must send to authenticate against the API.
PHOTOLIVE_AUTH_TOKEN=change-me

# Network
PORT=3001
HOST=0.0.0.0

# Logging: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Browsers allowed to call the API (comma-separated origins).
ALLOWED_ORIGINS=http://localhost:3001

# Storage paths (resolved relative to the working directory the server is started in).
DATABASE_PATH=./data/photolive.sqlite
PHOTOS_ROOT=./data/photos
RENDITIONS_ROOT=./data/renditions

# FTP ingest server (set FTP_PASV_URL to the LAN IP photographers will dial in to).
FTP_HOST=0.0.0.0
FTP_PORT=2121
FTP_PASV_URL=127.0.0.1
FTP_PASV_MIN=50000
FTP_PASV_MAX=50100

# OBS Studio websocket integration (leave blank to disable).
OBS_WEBSOCKET_URL=
OBS_WEBSOCKET_PASSWORD=
