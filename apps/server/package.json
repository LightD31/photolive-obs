{
  "name": "@photolive/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/static": "^8.0.3",
    "@fastify/websocket": "^11.0.1",
    "@photolive/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.0",
    "exifr": "^7.1.3",
    "fastify": "^5.2.0",
    "ftp-srv": "^4.6.3",
    "nanoid": "^5.0.9",
    "obs-websocket-js": "^5.0.6",
    "piscina": "^4.8.0",
    "pino": "^9.5.0",
    "sharp": "^0.34.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.0"
  }
}
