{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./dist",
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false,
    "esModuleInterop": true,
    "paths": {
      "@photolive/shared": ["../../packages/shared/src/index.ts"],
      "@photolive/shared/*": ["../../packages/shared/src/*"],
      "@photolive/server": ["../server/src/app.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
