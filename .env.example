# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Auth — single shared bearer token for control panel & API
PHOTOLIVE_AUTH_TOKEN=changeme-please

# CORS for the WS upgrade + control panel fetches
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://127.0.0.1:3001

# SQLite
DATABASE_PATH=./data/photolive.sqlite

# FTP server (multi-user; per-photographer credentials issued at runtime)
FTP_HOST=0.0.0.0
FTP_PORT=2121
FTP_PASV_URL=127.0.0.1
FTP_PASV_MIN=50000
FTP_PASV_MAX=50100

# Photo storage roots
PHOTOS_ROOT=./data/photos
RENDITIONS_ROOT=./data/renditions

# OBS WebSocket integration (optional)
OBS_WEBSOCKET_URL=
OBS_WEBSOCKET_PASSWORD=

# Slideshow control panel dev port
WEB_CONTROL_PORT=3002
WEB_SLIDESHOW_PORT=3001
